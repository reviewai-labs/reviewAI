REVIEWAI_HOST=127.0.0.1
REVIEWAI_PORT=8008
REVIEWAI_LOG_LEVEL=INFO
REVIEWAI_DEVICE=auto
REVIEWAI_BATCH_SIZE=16
# Path to the reviewAI-model workspace root.
# Leave blank for the local sibling-repo fallback to ../reviewAI-model.
REVIEWAI_MODEL_ROOT=
# Optional explicit manifest path. If unset, reviewAI uses
# <REVIEWAI_MODEL_ROOT>/artifacts/final_model_manifest.json.
REVIEWAI_MANIFEST_PATH=
# Comma-separated list of allowed browser origins.
REVIEWAI_ALLOWED_ORIGINS=*
